{
  "name": "metalsmith-safe-links",
  "version": "2.2.1",
  "description": "Metalsmith plugin to strip protocol and hostname from local links and to add target and rel attributes to external links",
  "type": "module",
  "exports": "./src/index.js",
  "files": [
    "src/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "test": "node --test --test-timeout=15000 'test/**/*.test.js'",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-timeout=15000 'test/**/*.test.js'",
    "test:coverage": "npm run coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "pre-release": "npm run lint:check && npm run format:check && npm test && npx metalsmith-plugin-mcp-server validate .",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "npm run lint:check && release-it --dry-run",
    "depcheck": "depcheck",
    "audit": "npm audit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wernerglinka/metalsmith-safe-links.git"
  },
  "keywords": [
    "metalsmith",
    "plugin"
  ],
  "author": "Werner Glinka <werner@glinka.co>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wernerglinka/metalsmith-safe-links/issues"
  },
  "homepage": "https://github.com/wernerglinka/metalsmith-safe-links#readme",
  "dependencies": {
    "cheerio": "1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "auto-changelog": "^2.5.0",
    "depcheck": "^1.4.7",
    "metalsmith": "^2.5.0",
    "release-it": "^20.0.0"
  }
}
